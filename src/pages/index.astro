---
import Svg from 'san-webkit-next/ui/core/Svg'
import Footer from 'san-webkit-next/ui/app/Footer'
import { cn } from 'san-webkit-next/ui/utils'

import Page from '$layouts/Page.astro'

import DomainCard from '$components/features/home/DomainCard.astro'
import GettingStartedCard from '$components/features/home/GettingStartedCard.astro'
import HeroChat from '$components/features/home/HeroChat.svelte'
import ForwardedEmailIcon from '$components/ui/icons/ForwardedEmail.svelte'
import SEO from '$components/layout/SEO.astro'

import illusBg from '$components/ui/illustrations/back.svg'

import { GETTING_STARTED, GUIDES, RESOURCES } from '$config/home'
import Button from 'san-webkit-next/ui/core/Button'

const bgImage = `url(${illusBg.src})`
---

<Page>
  <SEO
    slot="seo"
    title="Crypto Academy: Learn How to Analyze Cryptocurrency Market"
  />

  <Fragment>
    <link
      rel="preload"
      href={illusBg.src}
      as="image"
      type="image/svg+xml"
      fetchpriority="high"
    />
  </Fragment>

  <section class="flex flex-col" role="main">
    <div class="hero-bg min-h-[370px] px-5 py-14">
      <div
        class="container flex items-start justify-between md:flex-col md:items-center md:gap-10"
      >
        <div class="block">
          <h1 class="mb-8 text-3xl text-rhino">
            Try our AI Guide for Santiment Academy
          </h1>

          <div class="min-h-[152px] max-w-[600px]">
            <HeroChat client:load />
          </div>
        </div>

        <article class="rounded bg-porcelain p-10 md:w-full">
          <h3 class="mb-6 w-[164px] text-center text-lg md:mx-auto">
            Access our data with <span class="font-bold">AI connections</span>
          </h3>

          <Button
            class="justify-center bg-white hover:bg-mystic"
            href="/mcp-connector/"
          >
            Try now with Claude
          </Button>
        </article>
      </div>
    </div>

    <div class="container">
      <section class="mx-auto mb-20 mt-20 sm:mb-0 sm:mt-7">
        <h2 class="mb-8 text-xl text-rhino">Getting started</h2>

        <div
          class="grid w-full grid-cols-4 gap-6 md:grid-cols-2 sm:grid-cols-1"
        >
          {GETTING_STARTED.map((item) => <GettingStartedCard {...item} />)}
        </div>
      </section>

      <h4 class="mx-0 mb-8 mt-20 text-lg text-rhino sm:mb-5 sm:mt-12">
        Guides
      </h4>

      <div class="grid w-full grid-cols-4 gap-6 md:grid-cols-2 sm:grid-cols-1">
        {
          GUIDES.map(({ title, icon, ...rest }) => (
            <DomainCard {icon} {title} {...rest} />
          ))
        }
      </div>

      <h4 class="mx-0 mb-8 mt-20 text-lg text-rhino sm:mb-5 sm:mt-12">
        Resources
      </h4>

      <div class="grid w-full grid-cols-2 gap-6 md:grid-cols-2 sm:grid-cols-1">
        {
          RESOURCES.map(({ title, ...rest }) => (
            <DomainCard wide {title} {...rest} maxWidth="295px" />
          ))
        }
      </div>

      <section
        class={cn(
          'relative mt-20 flex items-center justify-center rounded bg-athens px-5 py-12 sm:flex-col sm:p-5 xs:mt-[50px]',
          "after:content-[''] after:left-1/2 after:absolute after:block after:w-px after:h-[104px] after:bg-porcelain sm:after:hidden",
        )}
      >
        <a
          href="https://santiment.net/discord"
          target="_blank"
          rel="noopener noreferrer"
          class={cn(
            'mx-7 flex w-full max-w-[458px] items-center rounded px-4 py-6 transition-all duration-100 ease-in-out',
            'group hover:cursor-pointer hover:-translate-y-0.5 hover:bg-white',
          )}
        >
          <div>
            <Svg
              id="discord"
              w={36}
              h={27}
              class="ml-6 mr-4 fill-casper group-hover:fill-rhino"
            />
          </div>
          <div>
            <h3 class="mb-1 text-lg text-rhino">Join our discord!</h3>
            <p class="text-sm text-waterloo">
              Talk directly with the Santiment Team
            </p>
          </div>
        </a>

        <a
          href="https://app.santiment.net/support"
          target="_blank"
          rel="noopener noreferrer"
          class={cn(
            'mx-7 flex w-full max-w-[458px] items-center rounded px-4 py-6 transition-all duration-100 ease-in-out',
            'group hover:cursor-pointer hover:-translate-y-0.5 hover:bg-white',
          )}
        >
          <div>
            <ForwardedEmailIcon
              class="ml-6 mr-4 fill-casper group-hover:fill-rhino"
            />
          </div>
          <div>
            <h3 class="mb-1 text-lg text-rhino">Contact us</h3>
            <p class="text-sm text-waterloo">
              Reach out to us directly via email
            </p>
          </div>
        </a>
      </section>
    </div>
  </section>

  <Footer class="mt-14" client:visible />
</Page>

<style define:vars={{ bgImage }}>
  @reference '#app.css';

  .hero-bg {
    background-image: var(--bgImage);
    @apply bg-cover bg-center bg-no-repeat;
  }
</style>
